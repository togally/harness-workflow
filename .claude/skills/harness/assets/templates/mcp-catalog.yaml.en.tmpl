# MCP Catalog - Harness Tool-Level Registry
# This catalog recommends MCPs based on project dependencies.
# Updated: {{DATE}}
#
# How it works:
# 1. During `harness install`, project dependencies are scanned
# 2. Matching triggers activate MCP recommendations
# 3. Adoption count reflects how many projects reported using this MCP
# 4. Confidence levels: low (newly cataloged), medium (3+ projects), high (7+ projects)

catalog:
  - id: mysql
    triggers: ["mysql-connector", "jdbc:mysql", "spring-boot-starter-data-jpa", "mybatis"]
    mcp_server: "mcp-mysql"
    install_hint: "Configure MySQL MCP server with your database connection"
    solves: ["data query", "table structure", "data validation"]
    adoption: 0
    confidence: low

  - id: redis
    triggers: ["spring-boot-starter-data-redis", "jedis", "lettuce", "ioredis"]
    mcp_server: "mcp-redis"
    install_hint: "Configure Redis MCP server with your Redis connection"
    solves: ["cache query", "key analysis", "cache validation"]
    adoption: 0
    confidence: low

  - id: nacos
    triggers: ["nacos-client", "spring-cloud-starter-alibaba-nacos", "com.alibaba.nacos"]
    mcp_server: "mcp-nacos-server"
    install_hint: "Configure Nacos MCP server with your Nacos address"
    solves: ["configuration", "service discovery", "environment variables"]
    adoption: 0
    confidence: low

  - id: postgresql
    triggers: ["postgresql", "pg", "psycopg2", "node-postgres"]
    mcp_server: "mcp-postgres"
    install_hint: "Configure PostgreSQL MCP server with your database connection"
    solves: ["data query", "table structure", "data validation"]
    adoption: 0
    confidence: low

  - id: mongodb
    triggers: ["mongodb", "mongoose", "spring-boot-starter-data-mongodb", "pymongo"]
    mcp_server: "mcp-mongo"
    install_hint: "Configure MongoDB MCP server with your connection string"
    solves: ["document query", "collection structure", "data validation"]
    adoption: 0
    confidence: low

  - id: elasticsearch
    triggers: ["elasticsearch", "spring-boot-starter-data-elasticsearch", "@elastic/elasticsearch"]
    mcp_server: "mcp-elasticsearch"
    install_hint: "Configure Elasticsearch MCP server with your cluster URL"
    solves: ["search query", "index analysis", "mapping inspection"]
    adoption: 0
    confidence: low
