# MCP 能力目录 - Harness 工具级注册表
# 本目录根据项目依赖推荐可用的 MCP 服务。
# 更新日期: {{DATE}}
#
# 工作原理:
# 1. 执行 `harness install` 时扫描项目依赖
# 2. 匹配的触发器会激活 MCP 推荐
# 3. 采纳计数反映有多少项目报告使用了此 MCP
# 4. 置信度: low（新编目）、medium（3+ 项目）、high（7+ 项目）

catalog:
  - id: mysql
    triggers: ["mysql-connector", "jdbc:mysql", "spring-boot-starter-data-jpa", "mybatis"]
    mcp_server: "mcp-mysql"
    install_hint: "使用数据库连接信息配置 MySQL MCP 服务"
    solves: ["数据查询", "表结构", "数据校验"]
    adoption: 0
    confidence: low

  - id: redis
    triggers: ["spring-boot-starter-data-redis", "jedis", "lettuce", "ioredis"]
    mcp_server: "mcp-redis"
    install_hint: "使用 Redis 连接信息配置 Redis MCP 服务"
    solves: ["缓存查询", "Key 分析", "缓存校验"]
    adoption: 0
    confidence: low

  - id: nacos
    triggers: ["nacos-client", "spring-cloud-starter-alibaba-nacos", "com.alibaba.nacos"]
    mcp_server: "mcp-nacos-server"
    install_hint: "使用 Nacos 地址配置 Nacos MCP 服务"
    solves: ["配置获取", "服务发现", "环境变量"]
    adoption: 0
    confidence: low

  - id: postgresql
    triggers: ["postgresql", "pg", "psycopg2", "node-postgres"]
    mcp_server: "mcp-postgres"
    install_hint: "使用数据库连接信息配置 PostgreSQL MCP 服务"
    solves: ["数据查询", "表结构", "数据校验"]
    adoption: 0
    confidence: low

  - id: mongodb
    triggers: ["mongodb", "mongoose", "spring-boot-starter-data-mongodb", "pymongo"]
    mcp_server: "mcp-mongo"
    install_hint: "使用连接字符串配置 MongoDB MCP 服务"
    solves: ["文档查询", "集合结构", "数据校验"]
    adoption: 0
    confidence: low

  - id: elasticsearch
    triggers: ["elasticsearch", "spring-boot-starter-data-elasticsearch", "@elastic/elasticsearch"]
    mcp_server: "mcp-elasticsearch"
    install_hint: "使用集群 URL 配置 Elasticsearch MCP 服务"
    solves: ["搜索查询", "索引分析", "映射检查"]
    adoption: 0
    confidence: low
