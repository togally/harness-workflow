# === 通用忽略 ===
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
dist/
build/

# === 外部工具与 IDE ===
/.claude/
/.codex/
/.idea/
/.qoder/
/.kimi/

# === 文档 / 产物 / worktrees ===
/docs/
/artifacts/
.worktrees/

# === macOS 元数据（req-28 / chg-01 新增）===
.DS_Store

# === harness workflow 目录 ===
# 规则意图：.workflow/ 整体入版本，仅下列明确子路径忽略。
# !.workflow/ 必须先于任何 .workflow/** 子忽略声明，否则否定规则被覆盖。
!.workflow/
.workflow/context/backup/
